# ============================================================
# CampusHire AI — Environment Variables
# Copy this file, rename to .env, and fill in your values.
# NEVER commit the actual .env to Git!
# ============================================================

# MongoDB connection string
# Option A — Local MongoDB:  mongodb://localhost:27017/campushireai
# Option B — MongoDB Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/campushireai
MONGODB_URI=mongodb+srv://campushireai:11112006@cluster0.ltqq9la.mongodb.net/campushireai?retryWrites=true&w=majority

# JWT secret — use a long random string (32+ chars) in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev_secret_change_this_in_production_abc123xyz

# Server port
PORT=3000

# Node environment: development | production
NODE_ENV=development

# Anthropic API key — required for Phase 6 AI features
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here